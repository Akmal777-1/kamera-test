<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kamera Tekshiruvi</title>
</head>
<body style="text-align:center; background:#121212; color:white; font-family:sans-serif; padding:20px;">
    <h3>Kamera Tizimi</h3>
    <video id="v" autoplay playsinline style="width:100%; max-width:400px; border:3px solid #00ff00; border-radius:15px;"></video>
    <br><br>
    <button onclick="openCam()" style="padding:15px 30px; font-size:18px; background:#00ff00; border:none; border-radius:10px; cursor:pointer; font-weight:bold;">KAMERANI YOQISH</button>
    <p id="status"></p>

    <script>
        async function openCam() {
            const v = document.getElementById('v');
            try {
                const s = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
                v.srcObject = s;
                document.getElementById('status').innerText = "Kamera muvaffaqiyatli ulandi!";
            } catch (err) {
                alert("Kameraga ruxsat berilmadi!");
            }
        }
    </script>
</body>
</html>
